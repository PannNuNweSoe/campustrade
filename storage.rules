rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read
    match /{allPaths=**} {
      allow read;
    }
    
    // Allow only authenticated users to upload to their own folder
    match /items/{userId}/{fileName} {
      allow write: if request.auth.uid == userId;
    }
  }
}
